Source: nginx-stable
Section: httpd
Priority: optional
Maintainer: Docker Hardened Images <dhi@docker.com>
Build-Depends: debhelper-compat (= 13),
 cmake,
 libpcre2-dev,
 libedit-dev,
 libgrpc++-dev,
 libssl-dev,
 libprotobuf-dev,
 libxml2-dev,
 libxslt1-dev,
 opentelemetry-cpp-dev,
 pkg-config,
 protobuf-compiler,
 protobuf-compiler-grpc,
