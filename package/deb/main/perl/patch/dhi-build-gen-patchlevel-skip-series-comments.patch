Origin: DHI-internal (DHI build harness)
Description: Skip blank and comment-only lines while generating Perl patchlevel metadata.
 dpkg/patch@v1 registers DHI CVE patches in debian/patches/series, and Perl's
 gen-patchlevel helper treats every series line as a patch filename. Ignoring
 comments preserves the upstream metadata behavior while allowing the canonical
 DHI dpkg/patch@v1 workflow.
Forwarded: not-needed (DHI build environment workaround only)

--- a/debian/gen-patchlevel
+++ b/debian/gen-patchlevel
@@ -40,6 +40,10 @@
 newest_mtime=0
 while read patch strip
 do
+    case "$patch" in
+        ''|'#'*) continue;;
+    esac
+
     if $showdate; then
         mtime=$(stat --format='%Y' $patchdir/$patch)
         if [ "$mtime" -gt "$newest_mtime" ]; then
