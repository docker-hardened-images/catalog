Origin: DHI-internal (DHI build harness)
Description: Skip IPv6 loopback tests when the builder cannot connect to ::1.
 The DHI BuildKit environment can allow IPv6 bind probes while timing out on
 actual local ::1 connects. These upstream tests otherwise hang for the OS
 connect timeout. Keep the tests active when a real IPv6 loopback connection
 succeeds, and skip only when the build environment cannot support it.
Forwarded: not-needed (DHI build environment workaround only)

--- a/cpan/IO-Socket-IP/t/04local-client-v6.t
+++ b/cpan/IO-Socket-IP/t/04local-client-v6.t
@@ -23,6 +23,29 @@
    diag( "Testing with IN6ADDR_LOOPBACK=$IN6ADDR_LOOPBACK_HOST; this may be because of odd networking" );
 }
 my $IN6ADDR_LOOPBACK_HEX = unpack "H*", $IN6ADDR_LOOPBACK;
+
+sub ipv6_loopback_connects {
+   my $server = IO::Socket::IP->new(
+      Listen => 1,
+      LocalHost => "::1",
+      LocalPort => "0",
+      Type => Socket::SOCK_STREAM(),
+      GetAddrInfoFlags => 0,
+   ) or return 0;
+
+   my $client = IO::Socket::IP->new(
+      PeerHost => "::1",
+      PeerService => $server->sockport,
+      Type => Socket::SOCK_STREAM(),
+      Timeout => 5,
+      GetAddrInfoFlags => 0,
+   ) or return 0;
+
+   my $accepted = $server->accept or return 0;
+   return 1;
+}
+
+ipv6_loopback_connects() or plan skip_all => "Unable to connect to ::1";
 
