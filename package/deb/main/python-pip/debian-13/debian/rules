#!/usr/bin/make -f

%:
	dh $@

# pip is a pure-Python universal wheel: there is nothing to configure, compile,
# or test at package build time. The interpreter is a runtime dependency, not a
# build dependency, which is what decouples pip's version from CPython's.
override_dh_auto_configure:

override_dh_auto_build:

override_dh_auto_test:

override_dh_installdocs:

override_dh_installchangelogs:

override_dh_auto_install:
	mkdir -p debian/tmp/usr/lib/python3/dist-packages debian/tmp/usr/bin
	unzip -q -o pip-*-py3-none-any.whl -d debian/tmp/usr/lib/python3/dist-packages
	set -e; for n in pip pip3; do \
		printf '#!/usr/bin/python3\nimport sys\nfrom pip._internal.cli.main import main\nsys.exit(main())\n' > debian/tmp/usr/bin/$$n; \
		chmod 0755 debian/tmp/usr/bin/$$n; \
	done
