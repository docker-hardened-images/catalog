# DHI packaging: drop the git-man dependency from the git package.
#
# Upstream makes the git binary package Depend on git-man (the manpages,
# Architecture: all). DHI runtime images do not ship manpages, so this
# dependency is unnecessary and only inflates the closure. Remove it from
# debian/control so the built git package no longer pulls in git-man.
--- a/debian/control
+++ b/debian/control
@@ -27,8 +27,7 @@
 Package: git
 Architecture: any
 Multi-Arch: foreign
-Depends: ${misc:Depends}, ${shlibs:Depends}, perl, liberror-perl,
- git-man (>> ${source:Upstream-Version}), git-man (<< ${source:Upstream-Version}-.)
+Depends: ${misc:Depends}, ${shlibs:Depends}, perl, liberror-perl
 Pre-Depends: ${misc:Pre-Depends}
 Recommends: ca-certificates, patch, less, ssh-client
 Suggests: gettext-base,
