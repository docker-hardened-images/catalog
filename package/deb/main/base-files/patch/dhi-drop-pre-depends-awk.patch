# DHI packaging: remove Pre-Depends on awk.
#
# Provenance: upstream base-files Pre-Depends on awk solely for its maintainer
# scripts (postinst, preinst).  DHI never runs maintainer scripts at image
# creation time, so the dependency is unnecessary.  The maintainer scripts
# themselves are removed in a separate pipeline step.
--- a/debian/control
+++ b/debian/control
@@ -11,7 +11,6 @@
 Package: base-files
 Provides: base, usr-is-merged
 Architecture: any
-Pre-Depends: awk
 Depends: ${misc:Depends}
 Essential: yes
 Priority: required
