# DHI packaging tweak (not upstream).
# Provenance:
# - Official amd64 `.deb`: `DEBIAN/conffiles` enumerates `/etc/debian_version`.
# - CI excerpt (docker-hardened-images/definitions, run 25970607578):
#   `dpkg: error processing package base-files (--configure): end of file on stdin at conffile prompt`
#   for `/etc/debian_version` during `TestDeb/runtime` (`apt-get install base-files`).
# Effect: post-`dh_installdeb`, drop only that conffile entry so non-interactive upgrades replace the file.
--- a/debian/rules
+++ b/debian/rules
@@ -79,5 +79,13 @@
 override_dh_installdeb:
 	dh_installdeb \
 	  '-DVENDORFILE=$(VENDORFILE)' \
 	  '-DUSR_MERGE_MULTILIB=$(USR_MERGE_MULTILIB)' \
 	  '-DUSR_MERGE_RTLDLIB=$(USR_MERGE_RTLDLIB)'
+
+# DHI packaging: Debian lists /etc/debian_version in DEBIAN/conffiles on published base-files binaries.
+# `TestDeb` apt installs invoke dpkg with no stdin attached; GH Actions `.build/package/deb/main/base-files/debian-13/13.yaml`
+# fails with EOF at the conffile prompt when staged trixie base images drift from Debian packaged md5sum tracking.
+execute_after_dh_installdeb:
+	test ! -f debian/base-files/DEBIAN/conffiles \
+	  || sed -i '/^\/etc\/debian_version$$/d' debian/base-files/DEBIAN/conffiles
+
