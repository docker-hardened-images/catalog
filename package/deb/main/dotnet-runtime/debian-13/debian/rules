#!/usr/bin/make -f

%:
	dh $@

# Microsoft ships prebuilt .NET runtime tarballs; there is nothing to configure,
# build, test, or clean from source.
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_clean:

# Do not strip or dwz-optimize the upstream prebuilt runtime binaries.
override_dh_strip:
override_dh_dwz:

# Runtime dependencies are declared explicitly in debian/control. The bundled
# runtime resolves libraries via rpath, which confuses dh_shlibdeps.
override_dh_shlibdeps:

override_dh_auto_install:
	mkdir -p debian/tmp/usr/lib/dotnet
	# Stage the extracted runtime tree. Exclude debian/ and the pipeline-generated
	# oci-config/ staging dir (that ships in the -oci-config package).
	find . -maxdepth 1 -mindepth 1 ! -name debian ! -name oci-config \
		-exec cp -a {} debian/tmp/usr/lib/dotnet/ \;
	# Expose dotnet on PATH via /usr/bin symlink (FHS-friendly).
	mkdir -p debian/tmp/usr/bin
	ln -sf ../lib/dotnet/dotnet debian/tmp/usr/bin/dotnet
	if [ -d debian/tmp/usr/lib/dotnet/tools ]; then \
		for tool in debian/tmp/usr/lib/dotnet/tools/*; do \
			ln -sf ../lib/dotnet/tools/$$(basename "$$tool") \
				debian/tmp/usr/bin/$$(basename "$$tool"); \
		done; \
	fi
	mkdir -p debian/tmp/opt/docker/config
	cp oci-config/*.yaml debian/tmp/opt/docker/config/
