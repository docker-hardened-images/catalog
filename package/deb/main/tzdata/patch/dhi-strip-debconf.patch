# DHI packaging: demote debconf from Depends to Recommends.
#
# Provenance: upstream tzdata Depends on debconf solely for its interactive
# timezone configuration scripts (config, postinst, postrm).  DHI never runs
# maintainer scripts at image creation time, so the hard dependency is
# unnecessary.  The DHI frontend resolves packages with --no-recommends,
# so this effectively makes debconf optional while preserving the relationship
# for users who inspect the package metadata.
--- a/debian/control
+++ b/debian/control
@@ -21,7 +21,7 @@
 Package: tzdata
 Architecture: all
 Multi-Arch: foreign
-Depends: debconf | debconf-2.0, ${misc:Depends}
+Recommends: debconf | debconf-2.0, ${misc:Depends}
 Breaks: tzdata-legacy (= 2023c-8), tzdata-legacy (= 2023c-9)
 Replaces: tzdata-legacy (= 2023c-8), tzdata-legacy (= 2023c-9)
 Provides: tzdata-trixie
