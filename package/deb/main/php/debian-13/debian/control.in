Source: php-@PHP_MAJOR_MINOR@
Section: php
Priority: optional
Maintainer: Docker Hardened Images <dhi@docker.com>
Build-Depends:
 debhelper-compat (= 13),
 bison,
 build-essential,
 libargon2-dev,
 libcurl4-openssl-dev,
 libicu-dev,
 libonig-dev,
 libpcre2-dev,
 libreadline-dev,
 libsodium-dev,
 libsqlite3-dev,
 libssl-dev,
 libxml2-dev,
 pkg-config,
 re2c,
 zlib1g-dev
Standards-Version: 4.7.0
Homepage: https://www.php.net/

Package: php-@PHP_MAJOR_MINOR@
Architecture: any
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 ca-certificates,
 libargon2-1,
 libcurl4t64,
 libicu76,
 libonig5,
 libpcre2-8-0,
 libreadline8t64,
 libsodium23,
 libsqlite3-0,
 libssl3t64,
 libxml2,
 zlib1g
Provides: php-cli-@PHP_MAJOR_MINOR@ (= ${binary:Version})
Description: PHP @PHP_MAJOR_MINOR@ interpreter and core modules
 PHP is a widely-used general-purpose scripting language. This package
 ships the PHP @PHP_MAJOR_MINOR@ CLI interpreter, runtime libraries, and
 default configuration under /etc/php-@PHP_MAJOR_MINOR@/.

Package: php-@PHP_MAJOR_MINOR@-fpm
Architecture: any
Depends: php-@PHP_MAJOR_MINOR@ (= ${binary:Version}), ${misc:Depends}
Provides: php-fpm-@PHP_MAJOR_MINOR@ (= ${binary:Version})
Description: FastCGI Process Manager for PHP @PHP_MAJOR_MINOR@
 PHP-FPM (FastCGI Process Manager) for PHP @PHP_MAJOR_MINOR@, including
 default pool configuration under /etc/php-@PHP_MAJOR_MINOR@/.

Package: php-@PHP_MAJOR_MINOR@-phpdbg
Architecture: any
Depends: php-@PHP_MAJOR_MINOR@ (= ${binary:Version}), ${misc:Depends}
Provides: php-phpdbg-@PHP_MAJOR_MINOR@ (= ${binary:Version})
Description: Interactive PHP debugger for PHP @PHP_MAJOR_MINOR@
 phpdbg interactive debugger for PHP @PHP_MAJOR_MINOR@.

Package: php-@PHP_MAJOR_MINOR@-dev
Architecture: any
Depends:
 php-@PHP_MAJOR_MINOR@ (= ${binary:Version}),
 ${misc:Depends},
 libc6-dev | libc-dev,
 libpcre2-dev,
 libxml2-dev,
 zlib1g-dev
Provides: php-dev-@PHP_MAJOR_MINOR@ (= ${binary:Version})
Description: Headers and tools to build PHP @PHP_MAJOR_MINOR@ extensions
 Development headers, phpize/php-config, and PEAR/PECL tooling for
 building extensions against PHP @PHP_MAJOR_MINOR@.

Package: php-@PHP_MAJOR_MINOR@-doc
Architecture: all
Depends: ${misc:Depends}
Provides: php-doc-@PHP_MAJOR_MINOR@ (= ${binary:Version})
Description: Documentation for PHP @PHP_MAJOR_MINOR@
 License files for PHP @PHP_MAJOR_MINOR@.

Package: php-@PHP_MAJOR_MINOR@-oci-config
Architecture: all
Depends: php-@PHP_MAJOR_MINOR@ (= ${binary:Version}), ${misc:Depends}
Description: OCI configuration for PHP @PHP_MAJOR_MINOR@
 OCI container configuration (environment variables and directory
 paths) for the PHP @PHP_MAJOR_MINOR@ package. Installing this package
 alongside php-@PHP_MAJOR_MINOR@ lets the image builder apply the PHP
 environment and runtime directories automatically.
