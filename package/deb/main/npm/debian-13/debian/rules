#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_configure:
override_dh_auto_build:
	# Extract the npm registry tarball
	mkdir -p npm-extract
	tar -xzf $(wildcard $(CURDIR)/../npm-*.tgz) -C npm-extract --strip-components=1

override_dh_auto_install:
	# Stage into FHS paths
	mkdir -p debian/tmp/usr/lib/nodejs/npm
	cp -R npm-extract/* debian/tmp/usr/lib/nodejs/npm/
	# Bump picomatch (CVE-2026-33671, CVE-2026-33672)
	$(CURDIR)/debian/vendor-replace.sh picomatch 4.0.4 \
		debian/tmp/usr/lib/nodejs/npm/node_modules/tinyglobby/node_modules
	# Bump brace-expansion (CVE-2026-33750)
	$(CURDIR)/debian/vendor-replace.sh brace-expansion 5.0.5 \
		debian/tmp/usr/lib/nodejs/npm/node_modules
	# Clean stray files
	rm -rf debian/tmp/usr/lib/nodejs/npm/node_modules/socks/.claude

override_dh_fixperms:
	dh_fixperms --exclude npm-cli.js --exclude npx-cli.js

override_dh_auto_test:
override_dh_auto_clean:
