# DHI-only patch (not upstream). Targets the Debian xdg-utils source package:
#   https://sources.debian.org/src/xdg-utils/1.2.1-2/scripts/Makefile.in/
#
# Make xdg-utils buildable in the offline DHI sandbox by neutering xmlto:
#  - the man/%.1 and %.txt rules call xmlto, which pulls down DocBook XSL
#    over the network even with --skip-validation; replace those recipes with
#    `touch` so the targets exist for the upstream Makefile but no docs are
#    actually generated. The package install step is already conditional on
#    the manpage file being non-empty (`if [ -f ... ]`), so the resulting
#    .deb just ships without manpages, which is fine for our use of xdg-utils.
#  - the empty %.txt files keep generate-help-script.awk from spinning in an
#    infinite getline loop on a missing file (its loop condition treats the
#    -1 error return as truthy).
#  - drop the README generation step from the `scripts` target. README is
#    produced by running each xdg-* helper with --help, which probes the
#    environment (e.g. xdg-screensaver / xdg-utils-common) and hangs in a
#    non-interactive build sandbox.
--- a/scripts/Makefile.in
+++ b/scripts/Makefile.in
@@ -35,7 +35,7 @@
 
 html:		html/index.html $(WEBPAGES)
 
-scripts:	README $(SCRIPTS)
+scripts:	$(SCRIPTS)
 
 man:		$(MANPAGES)
 
@@ -101,7 +101,7 @@
 xdg-terminal: xdg-terminal.in xdg-utils-common.in
 
 man/%.1: desc/%.xml
-	(cd man;$(XMLTO) man ../$<)
+	touch $@
 
 html/index.html: $(XMLFILES)
 	(cat html/index.html.pre; \
@@ -112,5 +112,5 @@
 	(cd html;$(XMLTO) html-nochunks ../$<)
 
 %.txt: desc/%.xml
-	$(XMLTO) txt $<
+	touch $@
 
