Origin: DHI-internal (DHI build harness)
Description: Allow DHI release suffixes in Debian linux version checks.
 Debian linux gencontrol validates trixie revisions before generating control
 metadata; DHI appends +dhiN to the Debian revision, so teach the trixie
 release rule to accept that local package suffix.
Forwarded: not-needed (DHI package versioning only)

--- a/debian/config/defines.toml
+++ b/debian/config/defines.toml
@@ -112,7 +112,7 @@
 [[debianrelease]]
 name_regex = 'trixie(-security)?'
 abi_suffix = '+deb13'
-revision_regex = '\d+(\.\d+)?(\+deb13u\d+)?'
+revision_regex = '\d+(\.\d+)?(\+deb13u\d+)?(\+dhi\d+)?'
 
 [[debianrelease]]
 name_regex = 'bookworm-backports'
