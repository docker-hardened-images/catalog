Subject: Update Jackson 2.18.6 to 2.18.8 for CVE remediation
Origin: DHI-internal CVE remediation
Reference: https://repo.maven.apache.org/maven2/com/fasterxml/jackson/core/jackson-databind/2.18.8/
Description: Gradle 8.14.5 pins Jackson 2.18.6 in its distribution dependency platform.
  Bump the 2.18 line to 2.18.8, which fixes CVE-2026-54512, CVE-2026-54513,
  and CVE-2026-54514 without crossing a major or minor Jackson version.

diff --git a/packaging/distributions-dependencies/build.gradle.kts b/packaging/distributions-dependencies/build.gradle.kts
index 72d7e5f45d4..e8f4f0c92a5 100644
--- a/packaging/distributions-dependencies/build.gradle.kts
+++ b/packaging/distributions-dependencies/build.gradle.kts
@@ -24,6 +24,6 @@ val asmVersion = "9.8"
 val awsS3Version = "1.12.780"
 val bouncycastleVersion = "1.84"
-val jacksonVersion = "2.18.6"
+val jacksonVersion = "2.18.8"
 val jaxbVersion = "3.0.0"
 val junit5Version = "5.8.2"
 val mavenVersion = "3.9.5"
