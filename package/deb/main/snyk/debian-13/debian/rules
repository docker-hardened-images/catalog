#!/usr/bin/make -f

%:
	dh $@

# Nothing to configure, build, test, or clean: we repackage a prebuilt,
# signed upstream binary that was already verified in the pipeline.
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_clean:

override_dh_auto_install:
	install -D -m0755 snyk debian/tmp/usr/bin/snyk

# The upstream binary embeds the legacy CLI bundle; stripping or computing
# shared-library dependencies on this foreign prebuilt artifact is neither
# safe nor meaningful.
override_dh_strip:
override_dh_dwz:
override_dh_shlibdeps:
