#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_autoreconf:

override_dh_installdocs:

override_dh_installchangelogs:

override_dh_auto_configure:
	./configure --prefix=/usr \
		--build="$$(dpkg-architecture --query DEB_BUILD_GNU_TYPE)" \
		--enable-ipv6 \
		--enable-loadable-sqlite-extensions \
		--enable-optimizations \
		--enable-shared \
		--with-lto \
		--with-computed-gotos \
		--with-dbmliborder=gdbm:ndbm \
		--without-ensurepip

override_dh_auto_build:
	$(MAKE) -j$$(nproc) \
		EXTRA_CFLAGS="-DTHREAD_STACK_SIZE=0x100000 -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer"

override_dh_auto_install:
	$(MAKE) DESTDIR=$(CURDIR)/debian/tmp install
	ln -sf idle3 debian/tmp/usr/bin/idle
	ln -sf pydoc3 debian/tmp/usr/bin/pydoc
	ln -sf python3 debian/tmp/usr/bin/python
	ln -sf python3-config debian/tmp/usr/bin/python-config
	find debian/tmp/usr -depth \
		\( \
			\( -type d -a \( -name test -o -name tests -o -name idle_test \) \) \
			-o \( -type f -a \( -name '*.pyc' -o -name '*.pyo' -o -name 'libpython*.a' \) \) \
		\) -exec rm -rf '{}' +

override_dh_auto_test:

override_dh_auto_clean:
