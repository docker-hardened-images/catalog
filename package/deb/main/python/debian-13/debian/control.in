Source: python-@PYTHON_MINOR@
Section: python
Priority: optional
Maintainer: Docker Hardened Images <dhi@docker.com>
Build-Depends:
 debhelper-compat (= 13),
 build-essential,
 ca-certificates,
 git,
 libbluetooth-dev,
 libbz2-dev,
 libdb-dev,
 libffi-dev,
 libgdbm-compat-dev,
 libgdbm-dev,
 liblzma-dev,
 libncurses-dev,
 libreadline-dev,
 libsqlite3-dev,
 libssl-dev,
 libzstd-dev,
 pkg-config,
 tk-dev,
 uuid-dev,
 zlib1g-dev
Standards-Version: 4.7.0
Homepage: https://www.python.org/

Package: libpython-@PYTHON_MINOR@-minimal
Architecture: all
Depends: ${misc:Depends}, libc6 (>= 2.34), libssl3t64 (>= 3.0.0)
Description: Minimal subset of the Python language (version @PYTHON_MINOR@)
 Shared library for Python @PYTHON_MINOR@.

