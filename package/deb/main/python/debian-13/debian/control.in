Source: python-@PYTHON_MINOR@
Section: python
Priority: optional
Maintainer: Docker Hardened Images <dhi@docker.com>
Build-Depends:
 debhelper-compat (= 13),
 build-essential,
 ca-certificates,
 git,
 libbluetooth-dev,
 libbz2-dev,
 libdb-dev,
 libffi-dev,
 libgdbm-compat-dev,
 libgdbm-dev,
 liblzma-dev,
 libncurses-dev,
 libreadline-dev,
 libsqlite3-dev,
 libssl-dev,
 libzstd-dev,
 pkg-config,
 tk-dev,
 uuid-dev,
 zlib1g-dev
Standards-Version: 4.7.0
Homepage: https://www.python.org/

Package: libpython-@PYTHON_MINOR@-minimal
Architecture: any
Multi-Arch: same
Depends: ${misc:Depends}, libc6 (>= 2.34), libssl3t64 (>= 3.0.0), libstdc++6 (>= 14)
Conflicts: libpython3-minimal, libpython@PYTHON_MINOR@-minimal, dhi-libpython3-minimal
Replaces: libpython3-minimal, libpython@PYTHON_MINOR@-minimal, dhi-libpython3-minimal
@PROVIDES_LIBPYTHON3_MINIMAL@
Description: Minimal subset of the Python language (version @PYTHON_MINOR@)
 Standard library modules for Python @PYTHON_MINOR@ (installed under
 /usr/lib/python@PYTHON_MINOR@).

Package: libpython-@PYTHON_MINOR@-stdlib
Architecture: any
Multi-Arch: same
Depends:
 ${misc:Depends},
 libpython-@PYTHON_MINOR@-minimal (= ${binary:Version}),
 libbz2-1.0,
 libc6 (>= 2.34),
 libcrypt1 (>= 1:4.1.0),
 libdb5.3t64,
 libffi8 (>= 3.4),
 libgdbm-compat4t64 (>= 1.23),
 libgdbm6 (>= 1.23),
 liblzma5 (>= 5.1.1alpha+20120614),
 libncursesw6 (>= 6.1),
 libreadline8t64 (>= 7.0~beta),
 libsqlite3-0 (>= 3.36.0),
 libtinfo6 (>= 6),
 libuuid1 (>= 2.20.1),
 libzstd1 (>= 1.5.0),
 zlib1g (>= 1:1.2.0)
Conflicts: libpython3-stdlib, libpython@PYTHON_MINOR@-stdlib, dhi-libpython3-stdlib
Replaces: libpython3-stdlib, libpython@PYTHON_MINOR@-stdlib, dhi-libpython3-stdlib
@PROVIDES_LIBPYTHON3_STDLIB@
Description: Python standard library (version @PYTHON_MINOR@)
 Metapackage pulling in the full standard library for Python @PYTHON_MINOR@
 (the module payload is shipped by libpython-@PYTHON_MINOR@-minimal).

Package: libpython-@PYTHON_MINOR@
Architecture: any
Multi-Arch: same
Depends:
 ${misc:Depends},
 libpython-@PYTHON_MINOR@-stdlib (= ${binary:Version}),
 libc6 (>= 2.34),
 libexpat1 (>= 2.6.0),
 zlib1g (>= 1:1.2.0)
Conflicts: libpython@PYTHON_MINOR@, dhi-libpython3
Replaces: libpython@PYTHON_MINOR@, dhi-libpython3
@PROVIDES_LIBPYTHON3@
Description: Shared Python runtime library (version @PYTHON_MINOR@)
 The libpython@PYTHON_MINOR@ shared library (libpython@PYTHON_MINOR@.so.1.0),
 installed under the multiarch library directory so it is a drop-in for
 Debian's libpython@PYTHON_MINOR@ package.

Package: python-@PYTHON_MINOR@-minimal
Architecture: any
Multi-Arch: allowed
Depends:
