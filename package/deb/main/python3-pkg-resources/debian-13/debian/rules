#!/usr/bin/make -f

%:
	dh $@

# pkg_resources is pure-Python: there is nothing to configure, compile, or test
# at package build time.
override_dh_auto_configure:

override_dh_auto_build:

override_dh_auto_test:

override_dh_installdocs:

override_dh_installchangelogs:

# Extract only pkg_resources from the setuptools 81.0.0 wheel and make it
# self-contained: relocate setuptools' _vendor tree to a private
# pkg_resources/_vendor and repoint pkg_resources' sys.path shim at it. This
# avoids any file overlap with the python3-setuptools package (which owns
# setuptools/ and setuptools/_vendor/) while keeping pkg_resources importable
# without setuptools present.
DIST := debian/tmp/usr/lib/python3/dist-packages
override_dh_auto_install:
	mkdir -p $(DIST)
	rm -rf unpacked
	unzip -q -o setuptools-*-py3-none-any.whl -d unpacked
	cp -a unpacked/pkg_resources $(DIST)/pkg_resources
	rm -rf $(DIST)/pkg_resources/tests
	mkdir -p $(DIST)/pkg_resources/_vendor
	cp -a unpacked/setuptools/_vendor/. $(DIST)/pkg_resources/_vendor/
	sed -i \
	  "s#os.path.join(os.path.dirname(os.path.dirname(__file__)), 'setuptools', '_vendor')#os.path.join(os.path.dirname(__file__), '_vendor')#" \
	  $(DIST)/pkg_resources/__init__.py
	grep -q "os.path.dirname(__file__), '_vendor'" $(DIST)/pkg_resources/__init__.py
	find $(DIST)/pkg_resources -name '*.exe' -delete
	find $(DIST)/pkg_resources -name requires.txt -delete
