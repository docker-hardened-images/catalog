#!/usr/bin/make -f

BUN_BINARY ?= $(firstword $(wildcard $(CURDIR)/../bun-staging/bun))

%:
	dh $@

override_dh_auto_configure:
override_dh_auto_build:

override_dh_auto_install:
	install -D -m 0755 "$(BUN_BINARY)" debian/tmp/usr/bin/bun
	ln -sf bun debian/tmp/usr/bin/bunx

override_dh_strip:
override_dh_auto_test:
override_dh_auto_clean:

# Prebuilt upstream binary; dwz fails on stripped upstream binary
override_dh_dwz:
