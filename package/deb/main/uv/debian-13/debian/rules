#!/usr/bin/make -f

include /usr/share/rustc/architecture.mk

export CARGO_HOME=$(CURDIR)/debian/cargo-home
export CARGO_TARGET_DIR=$(CURDIR)/target
export CARGO_BUILD_TARGET=$(DEB_HOST_RUST_TYPE)

%:
	dh $@ -v

override_dh_auto_configure:

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	cargo auditable install --locked --root debian/uv/usr --path crates/uv

execute_before_dh_installman:
	help2man --no-info \
		debian/uv/usr/bin/uv > debian/uv.1
	help2man --no-info \
		debian/uv/usr/bin/uvx > debian/uvx.1

override_dh_auto_clean:
	rm -rf $(CARGO_TARGET_DIR)
	rm -rf $(CARGO_HOME)
