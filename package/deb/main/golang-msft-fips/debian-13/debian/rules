#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_configure:

override_dh_auto_build:
	cd src && GOROOT_BOOTSTRAP=$(DHI_GOROOT_BOOTSTRAP) ./make.bash -v

	# Clean up build artifacts before staging
	rm -rf pkg/obj
	rm -rf pkg/bootstrap
	rm -rf pkg/tool/*/api
	rm -rf pkg/tool/*/dist*
	rm -rf pkg/*/cmd
	rm -rf pkg/tool/*/go_bootstrap
	rm -rf src/cmd/dist

override_dh_auto_install:
	mkdir -p debian/tmp/usr/lib/go/bin debian/tmp/usr/bin debian/tmp/usr/share/doc/go

	for bin in go gofmt; do \
		install -Dm755 bin/$$bin debian/tmp/usr/lib/go/bin/$$bin; \
		ln -s /usr/lib/go/bin/$$bin debian/tmp/usr/bin/$$bin; \
	done

	cp -a pkg lib debian/tmp/usr/lib/go/
	cp -r doc misc debian/tmp/usr/share/doc/go
	cp -a src debian/tmp/usr/lib/go/
	cp -p go.env debian/tmp/usr/lib/go/go.env

	rm -rf debian/tmp/usr/lib/go/pkg/obj
	rm -rf debian/tmp/usr/lib/go/pkg/bootstrap
	rm -rf debian/tmp/usr/lib/go/pkg/tool/*/api
	rm -rf debian/tmp/usr/lib/go/pkg/*/cmd
	rm -rf debian/tmp/usr/lib/go/pkg/tool/*/api
	rm -rf debian/tmp/usr/lib/go/pkg/tool/*/go_bootstrap
	rm -rf debian/tmp/usr/lib/go/src/cmd/dist/dist

	# Remove tests from /usr/lib/go/src, not needed at runtime
	find debian/tmp/usr/lib/go/src \( -type f -a -name "*_test.go" \) -delete
	find debian/tmp/usr/lib/go/src \( -type d -a -name "testdata" \) -exec rm -rf {} +
	find debian/tmp/usr/lib/go/src \( -type f -a -name "*.rc" \) -delete
	find debian/tmp/usr/lib/go/src \( -type f -a -name "*.bat" \) -delete
	find debian/tmp/usr/lib/go/src \( -type f -a -name "*.pem" \) -delete

	# Install pre-generated OCI config
	mkdir -p debian/tmp/opt/docker/config
	cp oci-config/*.yaml debian/tmp/opt/docker/config/

override_dh_auto_test:
override_dh_auto_clean:
