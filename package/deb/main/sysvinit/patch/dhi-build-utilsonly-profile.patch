Origin: DHI-internal (DHI build harness)
Description: Introduce DHI-only pkg.sysvinit.utilsonly build profile for sysvinit.
 Debian has no such profile; setting DEB_BUILD_PROFILES alone does not limit
 binary packages. This patch marks non-utils packages with <!profile> and
 skips dh_install/changelog steps for omitted binaries so only sysvinit-utils
 is produced for container-focused DHI builds.
Forwarded: not-needed (DHI package subset only)

--- a/debian/control
+++ b/debian/control
@@ -20,6 +20,7 @@
 Vcs-Browser: https://salsa.debian.org/debian/sysvinit
 
 Package: sysvinit-core
+Build-Profiles: <!pkg.sysvinit.utilsonly>
 Architecture: any
 Depends:
  initscripts,
@@ -85,6 +86,7 @@
  initscripts that were formerly in lsb-base.
 
 Package: sysv-rc
+Build-Profiles: <!pkg.sysvinit.utilsonly>
 Homepage: https://salsa.debian.org/debian/sysvinit
 Architecture: all
 Multi-Arch: foreign
@@ -99,6 +101,7 @@
  configured through symbolic links in /etc/rc?.d/.
 
 Package: initscripts
+Build-Profiles: <!pkg.sysvinit.utilsonly>
 Homepage: https://salsa.debian.org/debian/sysvinit
 Architecture: all
 Multi-Arch: foreign
@@ -121,6 +124,7 @@
  system at boot time and shut it down at halt or reboot time.
 
 Package: bootlogd
+Build-Profiles: <!pkg.sysvinit.utilsonly>
 Architecture: any
 Depends:
  sysvinit-utils (>= 3.05-1),
--- a/debian/rules
+++ b/debian/rules
@@ -41,6 +41,9 @@
 override_dh_install-arch:
 	dh_install
 
+ifneq (,$(filter pkg.sysvinit.utilsonly,$(DEB_BUILD_PROFILES)))
+	@:
+else
 	# sysvinit package
 	if test -e debian/share/inittab.$(DEB_HOST_GNU_TYPE) ; \
 	then \
@@ -61,6 +64,7 @@
 ifneq (,$(findstring $(DEB_HOST_ARCH_OS),linux kfreebsd))
 	$(INSTALL) -d $(inittmp)/sys
 endif
+endif
 
 ifeq ($(derives_from_ubuntu),yes)
 ifneq (,$(findstring sysvinit-utils, $(shell dh_listpackages)))
@@ -73,9 +77,13 @@
 	dh $@ $(DH_OPTIONS)
 
 override_dh_installchangelogs-arch:
+ifneq (,$(filter pkg.sysvinit.utilsonly,$(DEB_BUILD_PROFILES)))
+	dh_installchangelogs -psysvinit-utils --exclude doc/Changelog
+else
 	dh_installchangelogs -psysvinit-core doc/Changelog
 	dh_installchangelogs -psysvinit-utils --exclude doc/Changelog
 	dh_installchangelogs -pbootlogd
+endif
 
 override_dh_installchangelogs-indep:
 	dh_installchangelogs
