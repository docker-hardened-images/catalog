#!/usr/bin/make -f

# GCC 14 has stricter constexpr evaluation that breaks V8's bundled abseil
# on arm64. Relax with -fpermissive until upstream fixes it.
export DEB_CXXFLAGS_APPEND = -fpermissive

%:
	dh $@

override_dh_auto_configure:
	./configure --prefix=/usr --ninja $(DHI_CONFIGURE_OPTS)

override_dh_auto_build:
	$(MAKE) -j$$(nproc) BUILDTYPE=Release

override_dh_auto_install:
	$(MAKE) DESTDIR=$(CURDIR)/debian/tmp install

# node binary is too large for dwz DWARF optimization
override_dh_dwz:

# corepack/npm are packaged separately; docs and man pages are not shipped
override_dh_missing:
	dh_missing --list-missing

override_dh_auto_test:
override_dh_auto_clean:
