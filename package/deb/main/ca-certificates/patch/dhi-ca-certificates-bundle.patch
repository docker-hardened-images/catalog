# DHI packaging: add a ca-certificates-bundle binary package.
#
# Provenance: upstream ca-certificates produces ca-certificates (with openssl +
# debconf deps) and ca-certificates-udeb (installer-only).  Neither is suitable
# for minimal DHI static images.
#
# This patch appends a ca-certificates-bundle stanza to debian/control (no
# Depends) and an execute_before_dh_installdeb target to debian/rules that
# concatenates the already-built mozilla/ PEM files into a single
# /etc/ssl/certs/ca-certificates.crt.  dpkg-buildpackage produces the bundle
# .deb natively alongside the existing packages.
--- a/debian/control
+++ b/debian/control
@@ -37,3 +37,10 @@
  .
  This package is for use in the installer environment only.
  Do not install on a normal system.
+
+Package: ca-certificates-bundle
+Architecture: all
+Description: CA certificate bundle for minimal images
+ Pre-concatenated Mozilla CA certificate bundle for DHI static runtime
+ images.  No update-ca-certificates script, no individual cert files,
+ no debconf, no runtime dependencies.
--- a/debian/rules
+++ b/debian/rules
@@ -23,3 +23,8 @@
 	find $(CURDIR)/debian/ca-certificates/usr/share/ca-certificates -type f -name '*.crt' -printf '%P\n' | \
 	 LC_ALL=C sort | sed -e '$$! s/$$/, /' | tr -d '\n' > debian/config.initial_certs
 	dh_installdebconf -n -DINITIAL_CERTS=@debian/config.initial_certs
+
+# ca-certificates-bundle: concatenated PEM bundle only
+execute_before_dh_installdeb:
+	install -d -m 0755 debian/ca-certificates-bundle/etc/ssl/certs
+	find mozilla -name "*.crt" | sort | xargs cat > debian/ca-certificates-bundle/etc/ssl/certs/ca-certificates.crt
