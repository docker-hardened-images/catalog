#!/usr/bin/make -f
%:
	dh $@

override_dh_autoreconf:
override_dh_auto_configure:
	gnuArch="$$(dpkg-architecture --query DEB_BUILD_GNU_TYPE)" && \
	CC="$$gnuArch-gcc" CXX="$$gnuArch-g++" \
	CFLAGS="-fPIC -g -O2 -ffunction-sections -fdata-sections" \
	CXXFLAGS="-fPIC -g -O2 -ffunction-sections -fdata-sections" \
	LDFLAGS="-Wl,--gc-sections" \
	./configure --prefix=/usr \
		--build="$$gnuArch" \
		--target="$$gnuArch" \
		--host="$$gnuArch" \
		--disable-silent-rules \
		--disable-nls \
		--disable-werror \
		--disable-multilib \
		--disable-gprofng \
		--disable-gdb \
		--disable-gdbserver \
		--disable-compressed-debug-sections \
		--disable-x86-used-note \
		--disable-default-execstack \
		--disable-static \
		--enable-deterministic-archives \
		--enable-plugins \
		--enable-threads \
		--enable-jansson \
		--enable-new-dtags \
		--enable-ld=default \
		--enable-gold \
		--enable-shared \
		--enable-default-hash-style=gnu \
		--enable-textrel-check=error \
		--with-gold-ldflags=-static-libstdc++ \
		--with-system-zlib

override_dh_auto_build:
	$(MAKE)

override_dh_auto_install:
	$(MAKE) install DESTDIR=$(CURDIR)/debian/tmp
	# Strip executables and shared libraries
	find debian/tmp/usr/bin -type f -executable -exec strip {} \; 2>/dev/null || true
	find debian/tmp/usr/lib -name '*.so*' -type f -exec strip --strip-unneeded {} \; 2>/dev/null || true
	# Remove files we do not ship
	rm -rf debian/tmp/usr/share
	rm -rf debian/tmp/usr/include
	rm -f debian/tmp/usr/lib/*.la
	rm -f debian/tmp/usr/lib/*.a
	rm -f debian/tmp/usr/lib/bfd-plugins/*.la
	# Strip arch-specific binaries
	gnuArch="$$(dpkg-architecture --query DEB_BUILD_GNU_TYPE)" && \
		find "debian/tmp/usr/$$gnuArch/bin" -type f -executable -exec strip {} \; 2>/dev/null || true

override_dh_auto_test:
override_dh_auto_clean:
override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
