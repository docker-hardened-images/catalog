Source: binutils-latest
Section: devel
Priority: optional
Maintainer: Docker Hardened Images <dhi@docker.com>
Build-Depends: debhelper-compat (= 13), build-essential, automake, autotools-dev, bison, flex, texinfo, zlib1g-dev, pkg-config, libjansson-dev
Standards-Version: 4.7.0

Package: binutils-latest
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}, binutils-latest-common (= ${binary:Version}), libbinutils-latest (= ${binary:Version}), libctf0-latest (= ${binary:Version}), libctf-nobfd0-latest (= ${binary:Version})
Provides: binutils, elf-binutils
Conflicts: binutils
Replaces: binutils
Description: GNU assembler, linker and binary utilities (latest upstream)
 The programs in this package are used to assemble, link and manipulate
 binary and object files. They may be used in conjunction with a compiler
 and various libraries to build programs.
Homepage: https://www.gnu.org/software/binutils/

Package: binutils-latest-common
Architecture: any
Depends: ${misc:Depends}
Provides: binutils-common
Conflicts: binutils-common
Replaces: binutils-common
Description: Common files for the GNU assembler, linker and binary utilities (latest upstream)
 This package contains the bfd-plugins directory used by binutils packages.
 It is not useful on its own.
Homepage: https://www.gnu.org/software/binutils/

Package: libbinutils-latest
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}, binutils-latest-common (= ${binary:Version})
Provides: libbinutils
Conflicts: libbinutils
Replaces: libbinutils
Description: GNU binary utilities (private shared library, latest upstream)
 This package includes the private shared libraries libbfd and libopcodes.
Homepage: https://www.gnu.org/software/binutils/

Package: libctf-nobfd0-latest
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}
Provides: libctf-nobfd0
Conflicts: libctf-nobfd0
Replaces: libctf-nobfd0
Description: Compact C Type Format library (runtime, no BFD dependency, latest upstream)
 This package includes the libctf-nobfd shared library. The Compact C Type
 Format (CTF) is a way of representing information about a binary program.
Homepage: https://www.gnu.org/software/binutils/

Package: libctf0-latest
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends}, libbinutils-latest (= ${binary:Version})
Provides: libctf0
Conflicts: libctf0
Replaces: libctf0
Description: Compact C Type Format library (runtime, BFD dependency, latest upstream)
 This package includes the libctf shared library. The Compact C Type
 Format (CTF) is a way of representing information about a binary program.
Homepage: https://www.gnu.org/software/binutils/

Package: binutils-latest-@ARCH@-linux-gnu
Architecture: any
Depends: ${misc:Depends}, binutils-latest-common (= ${binary:Version})
Provides: binutils-@ARCH@-linux-gnu
Conflicts: binutils-@ARCH@-linux-gnu
Replaces: binutils-@ARCH@-linux-gnu
Description: GNU binary utilities, for @ARCH@-linux-gnu target (latest upstream)
 This package provides GNU assembler, linker and binary utilities
 for the @ARCH@-linux-gnu target.
Homepage: https://www.gnu.org/software/binutils/
