#!/usr/bin/make -f

%:
	dh $@

# setuptools is a pure-Python universal wheel: there is nothing to configure,
# compile, or test at package build time.
override_dh_auto_configure:

override_dh_auto_build:

override_dh_auto_test:

override_dh_installdocs:

override_dh_installchangelogs:

override_dh_auto_install:
	mkdir -p debian/tmp/usr/lib/python3/dist-packages debian/tmp/usr/share/python-wheels
	unzip -q -o setuptools-*-py3-none-any.whl -d debian/tmp/usr/lib/python3/dist-packages
	cp setuptools-*-py3-none-any.whl debian/tmp/usr/share/python-wheels/
