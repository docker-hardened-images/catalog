Description: Align util-linux dh_install inputs with staged build-tree outputs
 lastlog2, uuid-runtime, and util-linux.install (fstrim) ship systemd/tmpfiles snippets that
 Debian usually expects inside debian/tmp first; constrained dpkg builders leave freshly
 generated artifacts under misc-utils/ or sys-utils/ until dh_install copies them explicitly.
 Use merged-usr systemd paths trixie’s dh_installsystemd understands.
Origin: adapted for DHI (dh_install / dh_installsystemd missing systemd units).


--- a/debian/lastlog2.install
+++ b/debian/lastlog2.install
@@ -1,8 +1,8 @@
 #!/usr/bin/dh-exec
 usr/bin/lastlog2
 # begin-remove-after: released:trixie
-[linux-any] usr/lib/systemd/system/lastlog2-import.service
+[linux-any] misc-utils/lastlog2-import.service usr/lib/systemd/system/
 # end-remove-after
-[linux-any] usr/lib/tmpfiles.d/lastlog2-tmpfiles.conf
+[linux-any] misc-utils/lastlog2-tmpfiles.conf usr/lib/tmpfiles.d/
 usr/share/bash-completion/completions/lastlog2
 <!nodoc> usr/share/man/man8/lastlog2.8

--- a/debian/uuid-runtime.install
+++ b/debian/uuid-runtime.install
@@ -1,9 +1,10 @@
 #!/usr/bin/dh-exec
-[linux-any] ${deb_systemdsystemunitdir}/uuidd.*
+[linux-any] misc-utils/uuidd.service usr/lib/systemd/system/
+[linux-any] misc-utils/uuidd.socket usr/lib/systemd/system/
 usr/bin/uuidgen
 usr/bin/uuidparse
-[linux-any] usr/lib/sysusers.d/uuidd-sysusers.conf
-[linux-any] usr/lib/tmpfiles.d/uuidd-tmpfiles.conf
+[linux-any] misc-utils/uuidd-sysusers.conf usr/lib/sysusers.d/
+[linux-any] misc-utils/uuidd-tmpfiles.conf usr/lib/tmpfiles.d/
 [linux-any] usr/sbin/uuidd
 <!nodoc> usr/share/man/man1/uuidgen.1
 <!nodoc> usr/share/man/man1/uuidparse.1

--- a/debian/util-linux.install
+++ b/debian/util-linux.install
@@ -7,9 +7,9 @@
 [linux-any] sbin/mkswap usr/sbin/
 [!linux-any] debian/tmp/sbin/mkswap => /usr/sbin/mkswap.linux
 # weekly fstrim only available on linux
-[linux-any] ${deb_systemdsystemunitdir}/fstrim.timer
-[linux-any] ${deb_systemdsystemunitdir}/fstrim.service
+[linux-any] sys-utils/fstrim.timer usr/lib/systemd/system/
+[linux-any] sys-utils/fstrim.service usr/lib/systemd/system/
 bin/findmnt usr/bin
 [linux-any] bin/more usr/bin
 bin/mountpoint usr/bin
