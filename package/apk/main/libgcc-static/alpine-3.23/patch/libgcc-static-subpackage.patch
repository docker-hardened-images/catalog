# Backport the libgcc-static subpackage split from Alpine aports master.
# Upstream: https://github.com/alpinelinux/aports/commit/423a8ad043d07f2c7546c8ec3e2b0384cda360ae
# Alpine 3.23-stable gcc ships static libgcc files only inside libgcc; clang22 22.1.8
# declares a runtime dependency on libgcc-static, which is absent from Alpine 3.23 repos.

--- a/APKBUILD
+++ b/APKBUILD
@@ -152,7 +152,7 @@
 
 # libatomic is a dependency for openvswitch
 $_libatomic && subpackages="$subpackages libatomic::$CTARGET_ARCH"
-$_libgcc && subpackages="$subpackages libgcc::$CTARGET_ARCH"
+$_libgcc && subpackages="$subpackages libgcc::$CTARGET_ARCH libgcc-static:libgccstatic:$CTARGET_ARCH"
 $_libquadmath && subpackages="$subpackages libquadmath::$CTARGET_ARCH"
 if $_libgomp; then
 	depends="$depends libgomp=$_gccrel"
@@ -607,6 +608,15 @@ libgcc() {
 	amove usr/lib/libgcc_s.so.*
 }
 
+libgccstatic() {
+	pkgdesc="GNU C compiler runtime libraries"
+	depends=
+
+	amove usr/lib/gcc/"$CTARGET"/"$pkgver"/crtbeginS.o
+	amove usr/lib/gcc/"$CTARGET"/"$pkgver"/crtendS.o
+	amove usr/lib/gcc/"$CTARGET"/"$pkgver"/libgcc.a
+}
+
 libgomp() {
 	pkgdesc="GCC shared-memory parallel programming API library"
 	depends=
