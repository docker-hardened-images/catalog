Use client_golang's version collector instead of prometheus/common's.

prometheus/common removed `version.NewCollector` in v0.50.0; the replacement
lives in `github.com/prometheus/client_golang/prometheus/collectors/version`.
The `prometheus/common/version` package is still used for the global Version,
Revision, Branch, BuildUser, and BuildDate variables populated by -ldflags.

Origin: DHI (adapts upstream main.go to the prometheus/common version bumped
 by the go/bump step in this package definition).
Upstream removal: https://github.com/prometheus/common/releases/tag/v0.50.0
Replacement package: https://pkg.go.dev/github.com/prometheus/client_golang/prometheus/collectors/version
Forwarded: not-needed (DHI bump-side adaptation; upstream beat-exporter still
 targets pre-v0.50.0 prometheus/common at v0.4.0).

diff --git a/main.go b/main.go
--- a/main.go
+++ b/main.go
@@ -17,6 +17,7 @@ import (

 	"github.com/prometheus/client_golang/prometheus"
 	"github.com/prometheus/client_golang/prometheus/promhttp"
+	versioncollector "github.com/prometheus/client_golang/prometheus/collectors/version"
 	"github.com/prometheus/common/version"
 	"github.com/trustpilot/beat-exporter/collector"
 	"github.com/trustpilot/beat-exporter/internal/service"
@@ -111,7 +112,7 @@ beatdiscovery:

 	// version metric
 	registry := prometheus.NewRegistry()
-	versionMetric := version.NewCollector(Name)
+	versionMetric := versioncollector.NewCollector(Name)
 	mainCollector := collector.NewMainCollector(httpClient, beatURL, Name, beatInfo, *systemBeat)
 	registry.MustRegister(versionMetric)
 	registry.MustRegister(mainCollector)
