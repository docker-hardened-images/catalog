# Docker Hardened Images — CPython security backport
# Summary: Reject control characters in POP3 commands (poplib)
# Upstream issue: https://github.com/python/cpython/issues/143923
# Upstream PR: https://github.com/python/cpython/pull/143924
# Upstream commit: https://github.com/python/cpython/commit/b234a2b67539f787e191d2ef19a7cbdce32874e7
#
# Unified diff adapted to the Python maintenance tarball for this pkg-python
# build; hunks may differ slightly from upstream `main`.
diff --git a/Lib/poplib.py b/Lib/poplib.py
--- a/Lib/poplib.py
+++ b/Lib/poplib.py
@@ -122,6 +122,8 @@ class POP3:
     def _putcmd(self, line):
         if self._debugging: print('*cmd*', repr(line))
         line = bytes(line, self.encoding)
+        if re.search(b'[\x00-\x1F\x7F]', line):
+            raise ValueError('Control characters not allowed in commands')
         self._putline(line)
 
 
