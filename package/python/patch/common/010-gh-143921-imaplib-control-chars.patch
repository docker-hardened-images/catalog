# Docker Hardened Images — CPython security backport
# Summary: Reject control characters in IMAP command arguments (imaplib)
# Upstream issue: https://github.com/python/cpython/issues/143921
# Upstream PR: https://github.com/python/cpython/pull/143922
# Upstream commit: https://github.com/python/cpython/commit/6262704b134db2a4ba12e85ecfbd968534f28b45
#
# Unified diff adapted to the Python maintenance tarball for this pkg-python
# build; hunks may differ slightly from upstream `main`.
diff --git a/Lib/imaplib.py b/Lib/imaplib.py
--- a/Lib/imaplib.py
+++ b/Lib/imaplib.py
@@ -129,7 +129,7 @@
 # We compile these in _mode_xxx.
 _Literal = br'.*{(?P<size>\d+)}$'
 _Untagged_status = br'\* (?P<data>\d+) (?P<type>[A-Z-]+)( (?P<data2>.*))?'
-
+_control_chars = re.compile(b'[\x00-\x1F\x7F]')
 
 
 class IMAP4:
@@ -1105,6 +1105,8 @@ class IMAP4:
         for arg in args:
             if arg is None: continue
             if isinstance(arg, str):
                 arg = bytes(arg, self._encoding)
+            if _control_chars.search(arg):
+                raise ValueError("Control characters not allowed in commands")
             data = data + b' ' + arg
 
         literal = self.literal
