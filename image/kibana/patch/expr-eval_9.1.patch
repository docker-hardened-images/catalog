Origin: DHI-internal (Kibana 9.1 build harness)
Description: Drop the unmaintained `expr-eval` dependency from the WorkChat
 calculator tools. The Kibana 9.1 yarn dependency bumps remove `expr-eval`
 (it carries an unpatched expression-evaluation vulnerability and is no
 longer published with fixes), so the two calculator tool modules that
 imported `expr-eval`'s `Parser` are rewritten to instead construct a
 `math-expression-evaluator` (`Mexp`) instance and call `.eval()` in place
 of `Parser.evaluate()`. `math-expression-evaluator@1.4.0` is added as a
 direct dependency in the build pipeline so the import resolves.
Forwarded: not-needed (DHI build-time source adaptation for a removed dependency)

diff --git a/x-pack/solutions/chat/plugins/workchat-app/server/services/orchestration/base_tools/calculator.ts b/x-pack/solutions/chat/plugins/workchat-app/server/services/orchestration/base_tools/calculator.ts
index 82c9f0d2eeb..8b00023ccf0 100644
--- a/x-pack/solutions/chat/plugins/workchat-app/server/services/orchestration/base_tools/calculator.ts
+++ b/x-pack/solutions/chat/plugins/workchat-app/server/services/orchestration/base_tools/calculator.ts
@@ -5,10 +5,11 @@
  * 2.0.
  */
 
-import { Parser } from 'expr-eval';
+import Mexp from 'math-expression-evaluator';
 import { z } from '@kbn/zod';
 import { type McpServerTool, toolResultFactory } from '@kbn/wci-server';
 
+const Parser = new Mexp();
 export const getCalculatorTool = (): McpServerTool => {
   return {
     name: 'calculator',
@@ -25,7 +26,7 @@ export const getCalculatorTool = (): McpServerTool => {
     },
     execute: async ({ input }) => {
       try {
-        return toolResultFactory.text(Parser.evaluate(input).toString());
+        return toolResultFactory.text(Parser.eval(input).toString());
       } catch (e) {
         return toolResultFactory.error(`Error evaluating expression: ${e.message}`);
       }
