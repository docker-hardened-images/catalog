{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "com.postman/postman-mcp-server",
    "description": "MCP server for the Postman API: operate on collections, workspaces, environments, and API specifications.",
    "repository": {
      "url": "https://github.com/postmanlabs/postman-mcp-server",
      "source": "github"
    },
    "version": "_VERSION_",
    "packages": [
      {
        "registryType": "oci",
        "registryBaseUrl": "https://dhi.io",
        "identifier": "postman-mcp:_VERSION_@__digest__",
        "version": "_VERSION_",
        "transport": { "type": "stdio" },
        "runtimeArguments": [
          { "type": "named", "name": "--rm" },
          { "type": "named", "name": "-i" }
        ],
        "environmentVariables": [
          {
            "name": "POSTMAN_API_KEY",
            "description": "A valid Postman API key.",
            "isRequired": true,
            "isSecret": true
          }
        ]
      }
    ]
}
