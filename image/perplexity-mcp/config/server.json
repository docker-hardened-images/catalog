{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "ai.perplexity/mcp-server",
    "title": "Perplexity API Platform",
    "description": "Real-time web search, reasoning, and research through Perplexity's API",
    "repository": {
      "url": "https://github.com/perplexityai/modelcontextprotocol",
      "source": "github"
    },
    "version": "_VERSION_",
    "packages": [
      {
        "registryType": "oci",
        "registryBaseUrl": "https://dhi.io",
        "identifier": "perplexity-mcp:_VERSION_@__digest__",
        "version": "_VERSION_",
        "transport": { "type": "stdio" },
        "runtimeArguments": [
          { "type": "named", "name": "--rm" },
          { "type": "named", "name": "-i" }
        ],
        "environmentVariables": [
          {
            "name": "PERPLEXITY_API_KEY",
            "description": "Perplexity API key. The server exits if this is absent.",
            "isRequired": true,
            "isSecret": true
          }
        ]
      }
    ]
  }
