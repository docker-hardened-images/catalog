From 1fb9c7d1e922d06e4fd1f00f5b467e90b45a870a Mon Sep 17 00:00:00 2001
From: DHI <dhi@docker.com>
Date: Fri, 27 Mar 2026 14:31:32 -0400
Subject: [PATCH] Fix sql_exporter.NewTarget call for v0.15.0 API

sql_exporter v0.15.0 added a job group (jg) parameter to NewTarget.
The new signature is NewTarget(logContext, tname, jg, dsn, ...) where
the previous was NewTarget(tname, dsn, ...). Pass an empty string for
the job group parameter to maintain existing behavior.
---
 internal/static/integrations/mssql/sql_exporter.go | 1 +
 1 file changed, 1 insertion(+)

diff --git a/internal/static/integrations/mssql/sql_exporter.go b/internal/static/integrations/mssql/sql_exporter.go
index a06d278..4ad15ce 100644
--- a/internal/static/integrations/mssql/sql_exporter.go
+++ b/internal/static/integrations/mssql/sql_exporter.go
@@ -122,6 +122,7 @@ func (c *Config) NewIntegration(l log.Logger) (integrations.Integration, error)
 	t, err := sql_exporter.NewTarget(
 		"mssqlintegration",
 		c.ConnectionName,
+		"",
 		string(c.ConnectionString),
 		[]*config.CollectorConfig{
 			&collectorConfig,
-- 
