{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.redis/mcp-redis",
  "title": "Redis MCP Server",
  "repository": {
    "url": "https://github.com/redis/mcp-redis",
    "source": "github"
  },
  "description": "Natural language interface designed for agentic applications to manage and search data in Redis.",
  "version": "_VERSION_",
  "packages": [
    {
      "registryType": "oci",
      "registryBaseUrl": "https://dhi.io",
      "identifier": "redis-mcp:_VERSION_@__digest__",
      "version": "_VERSION_",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--rm"
        },
        {
          "type": "named",
          "name": "-i"
        }
      ],
      "environmentVariables": [
        {
          "name": "REDIS_HOST",
          "description": "Redis server hostname.",
          "isRequired": false
        },
        {
          "name": "REDIS_PORT",
          "description": "Redis server port.",
          "isRequired": false
        },
        {
          "name": "REDIS_USERNAME",
          "description": "Redis username.",
          "isRequired": false
        },
        {
          "name": "REDIS_PWD",
          "description": "Redis password.",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "REDIS_SSL",
          "description": "Set to true to connect to Redis over TLS.",
          "isRequired": false
        },
        {
          "name": "REDIS_DB",
          "description": "Redis database index.",
          "isRequired": false
        }
      ]
    }
  ]
}
