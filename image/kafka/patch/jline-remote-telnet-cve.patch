This patch bumps Kafka's bundled JLine dependency to the fixed 4.2.1 release.
JLine 4.2.1 fixes remote-telnet resource exhaustion advisories affecting JLine 3.x.
Reference: https://github.com/jline/jline3/security/advisories/GHSA-2r2c-cx56-8933
Reference: https://github.com/jline/jline3/security/advisories/GHSA-47qp-hqvx-6r3f

diff --git a/gradle/dependencies.gradle b/gradle/dependencies.gradle
--- a/gradle/dependencies.gradle
+++ b/gradle/dependencies.gradle
@@ -71,2 +71,2 @@ versions += [
-  jline: "3.30.4",
+  jline: "4.2.1",
   jmh: "1.37",
diff --git a/shell/src/main/java/org/apache/kafka/shell/InteractiveShell.java b/shell/src/main/java/org/apache/kafka/shell/InteractiveShell.java
--- a/shell/src/main/java/org/apache/kafka/shell/InteractiveShell.java
+++ b/shell/src/main/java/org/apache/kafka/shell/InteractiveShell.java
@@ -122,3 +122,3 @@ public class InteractiveShell implements AutoCloseable {
     public int screenWidth() {
-        return terminal.getWidth();
+        return terminal.getSize().getColumns();
     }
