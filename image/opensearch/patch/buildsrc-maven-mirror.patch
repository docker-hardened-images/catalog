Subject: Use GCS Maven Central mirror for buildSrc dependencies
Origin: DHI build reliability
Reference: https://maven-central.storage-download.googleapis.com/maven2/
Description: OpenSearch buildSrc resolves Maven Central dependencies during
  build initialization before project-level repository rewrites are reliable.
  Use the same GCS Maven Central mirror pattern as the Kafka image to avoid
  Maven Central 429 responses from the cloud builder.

diff --git a/buildSrc/build.gradle b/buildSrc/build.gradle
--- a/buildSrc/build.gradle
+++ b/buildSrc/build.gradle
@@ -88,7 +88,9 @@ repositories {
       excludeGroupByRegex "adoptium.*|adoptopenjdk.*|openjdk.*"
     }
   }
-  mavenCentral {
+  maven {
+    name = "GCS Maven Central mirror"
+    url = uri("https://maven-central.storage-download.googleapis.com/maven2/")
     content {
       excludeGroupByRegex "adoptium.*|adoptopenjdk.*|openjdk.*"
     }
