From 1a95c61c632b9581bd13880f76406a31d0f5c655 Mon Sep 17 00:00:00 2001
From: DHI <dhi@docker.com>
Date: Fri, 27 Mar 2026 14:06:15 -0400
Subject: [PATCH] Bump Apache Spark from 3.5.4 to 3.5.7 to fix CVE-2025-54920

The spark-core, spark-sql-api, and spark-common-utils dependencies are
bumped from 3.5.4 to 3.5.7, which includes the fix for CVE-2025-54920
(Spark History Server Code Execution Vulnerability via Jackson
deserialization of event log data).

References:
- CVE-2025-54920
- https://github.com/advisories/GHSA-jwp6-cvj8-fw65
---
 build.gradle | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/build.gradle b/build.gradle
index be84ec7..8f17261 100644
--- a/build.gradle
+++ b/build.gradle
@@ -154,11 +154,11 @@ dependencies {
     compileOnly(group: 'software.amazon.awssdk', name: 'utils', version: "${versions.aws}")
     compileOnly(group: 'software.amazon.awssdk', name: 'sdk-core', version: "${versions.aws}")
 
-    spark 'org.apache.spark:spark-sql-api_2.13:3.5.4'
-    spark ('org.apache.spark:spark-core_2.13:3.5.4') {
+    spark 'org.apache.spark:spark-sql-api_2.13:3.5.7'
+    spark ('org.apache.spark:spark-core_2.13:3.5.7') {
         exclude group: 'org.eclipse.jetty', module: 'jetty-server'
     }
-    spark group: 'org.apache.spark', name: 'spark-common-utils_2.13', version: '3.5.4'
+    spark group: 'org.apache.spark', name: 'spark-common-utils_2.13', version: '3.5.7'
 
     implementation 'org.scala-lang:scala-library:2.13.9'
     implementation group: 'org.antlr', name: 'antlr4-runtime', version: '4.9.3'
@@ -217,9 +217,9 @@ task addSparkJar(type: Copy) {
     into sparkDir
 
     doLast {
-        def jarA = file("$sparkDir/spark-sql-api_2.13-3.5.4.jar")
-        def jarB = file("$sparkDir/spark-core_2.13-3.5.4.jar")
-        def jarC = file("$sparkDir/spark-common-utils_2.13-3.5.4.jar")
+        def jarA = file("$sparkDir/spark-sql-api_2.13-3.5.7.jar")
+        def jarB = file("$sparkDir/spark-core_2.13-3.5.7.jar")
+        def jarC = file("$sparkDir/spark-common-utils_2.13-3.5.7.jar")
 
         // 3a. Extract jar A to manipulate it
         def jarAContents = file("$buildDir/tmp/JarAContents")
-- 
2.51.0
