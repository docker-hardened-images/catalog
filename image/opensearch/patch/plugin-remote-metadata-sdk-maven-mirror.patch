Subject: Use GCS Maven Central mirror for remote metadata SDK build
Origin: DHI build reliability
Reference: https://maven-central.storage-download.googleapis.com/maven2/
Description: The remote metadata SDK build resolves normal dependencies from
  Maven Central and Gradle Plugin Portal. Use the same GCS Maven Central mirror
  pattern as the Kafka image before the plugin portal repository to avoid
  Maven Central 429 responses from the cloud builder.

diff --git a/build.gradle b/build.gradle
--- a/build.gradle
+++ b/build.gradle
@@ -33,8 +33,11 @@ buildscript {
     repositories {
         mavenLocal()
         maven { url = "https://ci.opensearch.org/ci/dbc/snapshots/maven/" }
         maven { url = "https://ci.opensearch.org/maven2/" }
-        mavenCentral()
+        maven {
+            name = "GCS Maven Central mirror"
+            url = "https://maven-central.storage-download.googleapis.com/maven2/"
+        }
         maven { url = "https://plugins.gradle.org/m2/" }
     }
 
@@ -57,8 +60,11 @@ allprojects {
     repositories {
         mavenLocal()
         maven { url = "https://ci.opensearch.org/ci/dbc/snapshots/maven/" }
         maven { url = "https://ci.opensearch.org/maven2/" }
-        mavenCentral()
+        maven {
+            name = "GCS Maven Central mirror"
+            url = "https://maven-central.storage-download.googleapis.com/maven2/"
+        }
         maven { url = "https://plugins.gradle.org/m2/" }
         maven { url = "https://artifacts.opensearch.org/releases/" }
     }
