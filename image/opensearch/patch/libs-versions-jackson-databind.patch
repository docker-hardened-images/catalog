Subject: Bump Jackson families for CVE remediation (2.21.x->2.22.0, 3.1.3->3.1.4)
Origin: DHI-internal CVE remediation
Reference: https://repo1.maven.org/maven2/tools/jackson/core/jackson-databind/3.1.4/
Description: OpenSearch 3.7.0 ships two Jackson families in its Gradle version
  catalog: the legacy 2.x line (com.fasterxml.jackson.*) and the new 3.x line
  (tools.jackson.*). The runtime image bundles tools.jackson.core:jackson-databind
  3.1.3, which is affected by CVE-2026-54512 through CVE-2026-54518 (fixed in
  3.1.4). Bump the 3.x family to 3.1.4 and align the 2.x family to 2.22.0 so both
  lines are remediated and plugin dependency graphs stay consistent.

diff --git a/gradle/libs.versions.toml b/gradle/libs.versions.toml
--- a/gradle/libs.versions.toml
+++ b/gradle/libs.versions.toml
@@ -8,11 +8,11 @@ bundled_jdk = "25.0.3+9"
 # optional dependencies
 spatial4j               = "0.7"
 jts                     = "1.15.0"
-jackson_annotations     = "2.21"
-jackson                 = "2.21.3"
-jackson_databind        = "2.21.3"
-jackson3                = "3.1.3"
-jackson3_databind       = "3.1.3"
+jackson_annotations     = "2.22"
+jackson                 = "2.22.0"
+jackson_databind        = "2.22.0"
+jackson3                = "3.1.4"
+jackson3_databind       = "3.1.4"
 snakeyaml               = "2.6"
 snakeyaml_engine        = "3.0.1"
 icu4j                   = "77.1"
