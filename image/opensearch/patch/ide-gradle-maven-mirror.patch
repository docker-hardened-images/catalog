Subject: Use GCS Maven Central mirror for IDE plugin dependencies
Origin: DHI build reliability
Reference: https://maven-central.storage-download.googleapis.com/maven2/
Description: OpenSearch gradle/ide.gradle resolves the gradle-idea-ext plugin
  through Gradle Plugin Portal, whose transitive dependencies may redirect to
  Maven Central and receive 429 responses from the cloud builder. Resolve the
  plugin artifact from Gradle Plugin Portal but source Maven Central
  transitive dependencies from the same GCS mirror used by the Kafka image.

diff --git a/gradle/ide.gradle b/gradle/ide.gradle
--- a/gradle/ide.gradle
+++ b/gradle/ide.gradle
@@ -19,6 +19,10 @@ import groovy.xml.XmlParser
 buildscript {
   repositories {
     maven {
       url = "https://ci.opensearch.org/maven2/"
     }
+    maven {
+      name = "GCS Maven Central mirror"
+      url = "https://maven-central.storage-download.googleapis.com/maven2/"
+    }
     maven {
       url = "https://plugins.gradle.org/m2/"
     }
