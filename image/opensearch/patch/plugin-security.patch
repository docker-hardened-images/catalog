Subject: Force patched Netty modules in the Security plugin
Upstream source: https://github.com/opensearch-project/security/blob/3.7.0.0/build.gradle
Patched dependency: https://repo.maven.apache.org/maven2/io/netty/netty-common/4.2.15.Final/
Description: The Security plugin already forces most Netty modules in 3.7.0.0.
  Force the remaining modules to the patched Netty family version used by
  OpenSearch.

diff --git a/build.gradle b/build.gradle
--- a/build.gradle
+++ b/build.gradle
@@ -489,6 +489,10 @@ configurations {
             force "io.netty:netty-buffer:${versions.netty}"
             force "io.netty:netty-codec-base:${versions.netty}"
+            force "io.netty:netty-codec:${versions.netty}"
+            force "io.netty:netty-codec-compression:${versions.netty}"
+            force "io.netty:netty-codec-classes-quic:${versions.netty}"
+            force "io.netty:netty-codec-native-quic:${versions.netty}"
             force "io.netty:netty-codec-http:${versions.netty}"
             force "io.netty:netty-codec-http2:${versions.netty}"
             force "io.netty:netty-codec-http3:${versions.netty}"
             force "io.netty:netty-common:${versions.netty}"
