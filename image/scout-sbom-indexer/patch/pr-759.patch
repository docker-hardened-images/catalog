From 227827f727b8c067f8820ca257c6d59bca2b61c4 Mon Sep 17 00:00:00 2001
From: Benjamin Grandfond <benjamin.grandfond@docker.com>
Date: Thu, 26 Mar 2026 11:10:57 +0100
Subject: [PATCH] chore(deps): bump syft from v1.38.2 to v1.42.3

Upgrades github.com/anchore/syft and its transitive dependencies.

Two code changes required:
- file.NewLocationFromDirectory gained a new `fd string` (FileSystemID)
  parameter in v1.42.x; pass "" to match syft's own internal usage
- TestFullCveDiscovery: update expected PURL for github.com/gofiber/template
  sub-module from the old subpath notation
  (pkg:golang/github.com/gofiber/template@3.1.8#django/v3) to the new
  full-path format (pkg:golang/github.com/gofiber/template/django/v3@3.1.8)
  introduced by the Go PURL fix in syft v1.39.0
---
 cves/cves_test.go               |   2 +-
 go.mod                          | 222 ++++++++-------
 go.sum                          | 461 ++++++++++++++++----------------
 internal/sbom/syft/fs/source.go |   2 +-
 4 files changed, 348 insertions(+), 339 deletions(-)

diff --git a/cves/cves_test.go b/cves/cves_test.go
index f09e9562d..cf29c065f 100644
--- a/cves/cves_test.go
+++ b/cves/cves_test.go
@@ -193,7 +193,7 @@ func TestFullCveDiscovery(t *testing.T) {
 
 	found := false
 	for _, pv := range sb.Vulnerabilities {
-		if pv.Purl == "pkg:golang/github.com/gofiber/template@3.1.8#django/v3" {
+		if pv.Purl == "pkg:golang/github.com/gofiber/template/django/v3@3.1.8" {
 			for _, v := range pv.Vulnerabilities {
 				if v.SourceId == "CVE-2024-22199" {
 					found = true
