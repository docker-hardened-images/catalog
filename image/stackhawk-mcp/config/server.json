{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "com.stackhawk/stackhawk",
    "description": "An MCP server that provides interaction with StackHawk's application security testing platform.",
    "repository": {
      "url": "https://github.com/stackhawk/stackhawk-mcp",
      "source": "github"
    },
    "version": "_VERSION_",
    "packages": [
      {
        "registryType": "oci",
        "registryBaseUrl": "https://dhi.io",
        "identifier": "stackhawk-mcp:_VERSION_@__digest__",
        "version": "_VERSION_",
        "transport": { "type": "stdio" },
        "runtimeArguments": [
          { "type": "named", "name": "-i" },
          { "type": "named", "name": "--rm" }
        ],
        "environmentVariables": [
          {
            "name": "STACKHAWK_API_KEY",
            "description": "StackHawk API key used to authenticate against the StackHawk platform.",
            "isRequired": true,
            "isSecret": true
          }
        ]
      }
    ]
  }
