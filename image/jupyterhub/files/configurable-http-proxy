#!/usr/local/bin/node
// Wrapper for configurable-http-proxy: bypasses the upstream `#!/usr/bin/env node`
// shebang, since /usr/bin/env is absent in the static DHI runtime. Loads the
// upstream CLI script as an ES module so commander still parses process.argv.
// .catch() ensures import failures (e.g. CHP layout changed in a future bump)
// surface as a non-zero exit, rather than an unhandled rejection that lets
// JupyterHub think the proxy launched.
"use strict";
import("/srv/configurable-http-proxy/bin/configurable-http-proxy").catch((e) => {
  console.error(e);
  process.exit(1);
});
