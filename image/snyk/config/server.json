{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.snyk/cli",
    "description": "Snyk MCP server exposing Snyk security scanning (code, open source, container, and IaC) to MCP clients via the snyk CLI over stdio.",
    "repository": {
      "url": "https://github.com/snyk/cli",
      "source": "github"
    },
    "version": "_VERSION_",
    "packages": [
      {
        "registryType": "oci",
        "registryBaseUrl": "https://dhi.io",
        "identifier": "snyk:_VERSION_@__digest__",
        "version": "_VERSION_",
        "transport": { "type": "stdio" },
        "runtimeArguments": [
          { "type": "named", "name": "--rm" },
          { "type": "named", "name": "-i" }
        ],
        "packageArguments": [
          { "type": "positional", "value": "mcp", "valueHint": "command" },
          { "type": "named", "name": "-t", "value": "stdio" }
        ],
        "environmentVariables": [
          {
            "name": "SNYK_TOKEN",
            "description": "Snyk API token used to authenticate the Snyk CLI / MCP server.",
            "isRequired": true,
            "isSecret": true
          }
        ]
      }
    ]
  }
