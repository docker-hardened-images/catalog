GHSA-72hv-8253-57qq: Quarkus platform constraints can still pull Jackson below
the jackson-bom version declared in gradle/libs.versions.toml.
Advisory: https://github.com/FasterXML/jackson-core/security/advisories/GHSA-72hv-8253-57qq
diff --git a/servers/quarkus-server/build.gradle.kts b/servers/quarkus-server/build.gradle.kts
--- a/servers/quarkus-server/build.gradle.kts
+++ b/servers/quarkus-server/build.gradle.kts
@@ -30,6 +30,19 @@
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
 
+// GHSA-72hv-8253-57qq: Quarkus platform constraints can still pull Jackson below the
+// jackson-bom version declared in gradle/libs.versions.toml. Force the Jackson core trio
+// so the Quarkus fast-jar packaging and SBOM reflect the fixed release.
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "com.fasterxml.jackson.core:jackson-core:2.22.0",
+      "com.fasterxml.jackson.core:jackson-databind:2.22.0",
+      "com.fasterxml.jackson.core:jackson-annotations:2.22",
+    )
+  }
+}
+
 val quarkusRunner =
   configurations.create("quarkusRunner") {
     description = "Used to reference the generated runner-jar (either fast-jar or uber-jar)"
