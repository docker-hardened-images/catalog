@@ -30,6 +30,20 @@ plugins {
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
 
+// GHSA-72hv-8253-57qq: Quarkus platform constraints currently pull Jackson 2.20.1.
+// Nessie already declares jackson-bom 2.21.1, but dependency resolution still selects 2.20.1.
+// Force the Jackson core trio to the fixed version so the Quarkus fast-jar packaging includes
+// the correct jar filenames and scanners/SBOM reflect 2.21.1.
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "com.fasterxml.jackson.core:jackson-core:2.21.1",
+      "com.fasterxml.jackson.core:jackson-databind:2.21.1",
+      "com.fasterxml.jackson.core:jackson-annotations:2.21",
+    )
+  }
+}
+
 val quarkusRunner by
   configurations.creating {
     description = "Used to reference the generated runner-jar (either fast-jar or uber-jar)"
