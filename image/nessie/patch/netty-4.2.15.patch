Force Netty 4.2.15.Final to resolve multiple CVEs against Quarkus BOM overrides.
https://github.com/netty/netty/releases/tag/netty-4.2.15.Final
Pinned per gradle/libs.versions.toml in Nessie 0.108.1.
diff --git a/servers/quarkus-server/build.gradle.kts b/servers/quarkus-server/build.gradle.kts
--- a/servers/quarkus-server/build.gradle.kts
+++ b/servers/quarkus-server/build.gradle.kts
@@ -30,6 +30,39 @@
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
 
+// Quarkus platform constraints and Nessie's declared Netty version still allow dependency
+// resolution to select older, vulnerable Netty releases. Force every Netty artifact to a
+// fixed version so the Quarkus fast-jar packaging includes the correct jar filenames and
+// scanners/SBOM reflect the patched release. Pinned to 4.2.15.Final to resolve multiple CVEs
+// (CVE-2026-44249, CVE-2026-45416, CVE-2026-45674, CVE-2026-47691, CVE-2026-44893,
+// CVE-2026-45673, CVE-2026-47244, CVE-2026-45536).
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "io.netty:netty-buffer:4.2.15.Final",
+      "io.netty:netty-codec-dns:4.2.15.Final",
+      "io.netty:netty-codec-haproxy:4.2.15.Final",
+      "io.netty:netty-codec-http2:4.2.15.Final",
+      "io.netty:netty-codec-http:4.2.15.Final",
+      "io.netty:netty-codec-socks:4.2.15.Final",
+      "io.netty:netty-codec:4.2.15.Final",
+      "io.netty:netty-common:4.2.15.Final",
+      "io.netty:netty-handler-proxy:4.2.15.Final",
+      "io.netty:netty-handler:4.2.15.Final",
+      "io.netty:netty-resolver-dns-classes-macos:4.2.15.Final",
+      "io.netty:netty-resolver-dns-native-macos:4.2.15.Final",
+      "io.netty:netty-resolver-dns:4.2.15.Final",
+      "io.netty:netty-resolver:4.2.15.Final",
+      "io.netty:netty-transport-classes-epoll:4.2.15.Final",
+      "io.netty:netty-transport-classes-kqueue:4.2.15.Final",
+      "io.netty:netty-transport-native-epoll:4.2.15.Final",
+      "io.netty:netty-transport-native-kqueue:4.2.15.Final",
+      "io.netty:netty-transport-native-unix-common:4.2.15.Final",
+      "io.netty:netty-transport:4.2.15.Final",
+    )
+  }
+}
+
 // GHSA-72hv-8253-57qq: Quarkus platform constraints can still pull Jackson below the
 // jackson-bom version declared in gradle/libs.versions.toml. Force the Jackson core trio
 // so the Quarkus fast-jar packaging and SBOM reflect the fixed release.
