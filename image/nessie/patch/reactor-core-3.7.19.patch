CVE-2025-22227: force reactor-netty 1.2.18 and reactor-core 3.7.19.
https://github.com/reactor/reactor-netty/releases/tag/v1.2.18
Applied after jackson and netty force patches in build.gradle.kts.
diff --git a/servers/quarkus-server/build.gradle.kts b/servers/quarkus-server/build.gradle.kts
--- a/servers/quarkus-server/build.gradle.kts
+++ b/servers/quarkus-server/build.gradle.kts
@@ -29,6 +29,20 @@
 }
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
+
+// Force reactor-netty to 1.2.18 to resolve CVE-2025-22227 (only fixed in reactor-netty
+// >= 1.2.8). reactor-netty 1.2.x belongs to the Reactor 2024.0 train and requires
+// reactor-core 3.7.x, so reactor-core is bumped from 3.5.x to 3.7.19 to keep the train
+// consistent.
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "io.projectreactor.netty:reactor-netty-http:1.2.18",
+      "io.projectreactor.netty:reactor-netty-core:1.2.18",
+      "io.projectreactor:reactor-core:3.7.19",
+    )
+  }
+}
 
