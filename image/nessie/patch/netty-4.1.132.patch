diff --git i/servers/quarkus-server/build.gradle.kts w/servers/quarkus-server/build.gradle.kts
index 93ff0b69c..de0c122ab 100644
--- i/servers/quarkus-server/build.gradle.kts
+++ w/servers/quarkus-server/build.gradle.kts
@@ -30,4 +30,35 @@ plugins {
 
+// CVE-2026-33870/CVE-2026-33871: Quarkus platform constraints currently pull Netty 4.1.130.
+// Nessie already declares Netty 4.2.10, but dependency resolution still selects 4.1.130.
+// Force the Netty dependencies to a fixed version so the Quarkus fast-jar packaging includes
+// the correct jar filenames and scanners/SBOM reflect 4.1.132.
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "io.netty:netty-buffer:4.1.132.Final",
+      "io.netty:netty-codec-dns:4.1.132.Final",
+      "io.netty:netty-codec-haproxy:4.1.132.Final",
+      "io.netty:netty-codec-http2:4.1.132.Final",
+      "io.netty:netty-codec-http:4.1.132.Final",
+      "io.netty:netty-codec-socks:4.1.132.Final",
+      "io.netty:netty-codec:4.1.132.Final",
+      "io.netty:netty-common:4.1.132.Final",
+      "io.netty:netty-handler-proxy:4.1.132.Final",
+      "io.netty:netty-handler:4.1.132.Final",
+      "io.netty:netty-resolver-dns-classes-macos:4.1.132.Final",
+      "io.netty:netty-resolver-dns-native-macos:4.1.132.Final",
+      "io.netty:netty-resolver-dns:4.1.132.Final",
+      "io.netty:netty-resolver:4.1.132.Final",
+      "io.netty:netty-transport-classes-epoll:4.1.132.Final",
+      "io.netty:netty-transport-classes-kqueue:4.1.132.Final",
+      "io.netty:netty-transport-native-epoll:4.1.132.Final",
+      "io.netty:netty-transport-native-kqueue:4.1.132.Final",
+      "io.netty:netty-transport-native-unix-common:4.1.132.Final",
+      "io.netty:netty-transport:4.1.132.Final",
+    )
+  }
+}
+
 val quarkusRunner by
   configurations.creating {
     description = "Used to reference the generated runner-jar (either fast-jar or uber-jar)"
