CVE-2026-42198 (GHSA-98qh-xjc8-98pq): force postgresql 42.7.11 against Quarkus BOM overrides.
https://github.com/pgjdbc/pgjdbc/security/advisories/GHSA-98qh-xjc8-98pq
Vert.x stays on Quarkus 3.37 BOM 4.5.28 (includes CVE-2026-6860 fix from 4.5.27).
diff --git a/servers/quarkus-server/build.gradle.kts b/servers/quarkus-server/build.gradle.kts
--- a/servers/quarkus-server/build.gradle.kts
+++ b/servers/quarkus-server/build.gradle.kts
@@ -30,6 +30,19 @@
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
 
+// CVE-2026-42198 (GHSA-98qh-xjc8-98pq): pgjdbc SCRAM-SHA-256 handshake CPU-exhaustion
+// DoS, fixed in 42.7.11. The Quarkus platform BOM can still constrain pgjdbc to 42.7.10,
+// so force the resolved jar to 42.7.11 so the fast-jar packaging and the SBOM/Scout scan
+// reflect the fixed version. Vert.x is managed by the Quarkus 3.37 BOM at 4.5.28, which
+// already includes the CVE-2026-6860 fix from 4.5.27; do not force vert.x 5.x here.
+configurations.configureEach {
+  resolutionStrategy {
+    force(
+      "org.postgresql:postgresql:42.7.11",
+    )
+  }
+}
+
 // CVE-2026-45292 (GHSA-rcgg-9c38-7xpx): unbounded memory allocation in
 // OpenTelemetry W3C baggage propagation, fixed in 1.62.0+. libs.versions.toml
 // declares opentelemetry 1.63.0, but the Quarkus platform BOM can still constrain
