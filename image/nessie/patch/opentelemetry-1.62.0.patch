CVE-2026-45292 (GHSA-rcgg-9c38-7xpx): force all io.opentelemetry artifacts to 1.62.0.
https://github.com/open-telemetry/opentelemetry-java/security/advisories/GHSA-rcgg-9c38-7xpx
Use 1.62.0 (not 1.63.0): Quarkus 3.37 calls ExporterBuilderUtil.validateEndpoint,
which was removed in OpenTelemetry 1.63.0.
diff --git a/servers/quarkus-server/build.gradle.kts b/servers/quarkus-server/build.gradle.kts
--- a/servers/quarkus-server/build.gradle.kts
+++ b/servers/quarkus-server/build.gradle.kts
@@ -30,6 +30,21 @@
 
 publishingHelper { mavenName = "Nessie - Quarkus Server" }
 
+// CVE-2026-45292 (GHSA-rcgg-9c38-7xpx): unbounded memory allocation in
+// OpenTelemetry W3C baggage propagation, fixed in 1.62.0+. libs.versions.toml
+// declares opentelemetry 1.63.0, but the Quarkus platform BOM can still constrain
+// individual OpenTelemetry jars to an older train. Pin to 1.62.0 (the minimum fixed
+// release): 1.63.0 removes ExporterBuilderUtil.validateEndpoint, which Quarkus 3.37
+// still invokes at startup.
+configurations.configureEach {
+  resolutionStrategy.eachDependency {
+    if (requested.group == "io.opentelemetry" && requested.version?.endsWith("-alpha") != true) {
+      useVersion("1.62.0")
+      because("CVE-2026-45292: force OpenTelemetry 1.62.0 (Quarkus 3.37 compatible, CVE fixed)")
+    }
+  }
+}
+
