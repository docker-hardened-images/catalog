Subject: [PATCH] Use absolute root path with SvelteKit resolve
# Source:
# - upstream Temporal UI v2.51.0 sources: https://github.com/temporalio/ui/tree/v2.51.0
# - generated against upstream commit 5efd7d9200df2e5bfbf7e0ef17547a52949c564a
#   ("chore: bump version to 2.51.0 (#3503)")
# - SvelteKit resolve runtime validation from the 2.60.x line: https://github.com/sveltejs/kit
# - this is a DHI-local compatibility patch, not a cherry-pick from an
#   upstream Temporal UI fix commit
#
# What this patch is for:
# Temporal UI still uses resolve('', {}) to generate links to the app root.
# DHI overrides @sveltejs/kit to 2.60.1 for CVE remediation, and that runtime
# rejects empty route IDs. Use resolve('/', {}) instead, which preserves the
# root-link behavior while satisfying SvelteKit's absolute-path requirement.
#
# How this patch was generated:
# - started from upstream Temporal UI v2.51.0 sources at commit
#   5efd7d9200df2e5bfbf7e0ef17547a52949c564a
# - replaced only the three resolve('', {}) calls used for root navigation and
#   API base-path construction with resolve('/', {})
# - generated the final patch with git diff

diff --git a/src/lib/holocene/navigation/cloud-nav-bar.svelte b/src/lib/holocene/navigation/cloud-nav-bar.svelte
index 93c657f1..31f0f0e7 100644
--- a/src/lib/holocene/navigation/cloud-nav-bar.svelte
+++ b/src/lib/holocene/navigation/cloud-nav-bar.svelte
@@ -35,7 +35,7 @@
   <div
     class="flex flex-row items-center justify-start group-data-[nav=open]:min-h-7"
   >
-    <a href={resolve('', {})} class="text-inherit flex items-center">
+    <a href={resolve('/', {})} class="text-inherit flex items-center">
       <Logo
         height={24}
         width={24}
diff --git a/src/lib/holocene/navigation/oss-nav-bar.svelte b/src/lib/holocene/navigation/oss-nav-bar.svelte
index 56561e5e..b33db4c5 100644
--- a/src/lib/holocene/navigation/oss-nav-bar.svelte
+++ b/src/lib/holocene/navigation/oss-nav-bar.svelte
@@ -32,7 +32,7 @@
   class="flex items-center justify-between pb-4 group-data-[nav=closed]:flex-col group-data-[nav=closed]:gap-2"
 >
   <div class="flex w-fit items-center gap-1 text-nowrap">
-    <a href={resolve('', {})} class="flex items-center">
+    <a href={resolve('/', {})} class="flex items-center">
       <Logo height={24} width={24} class="m-1" />
     </a>
     {#if subtitleHref}
diff --git a/src/lib/utilities/route-for-api.ts b/src/lib/utilities/route-for-api.ts
index ce85a04c..219bda2a 100644
--- a/src/lib/utilities/route-for-api.ts
+++ b/src/lib/utilities/route-for-api.ts
@@ -81,7 +81,7 @@ export const routeForApi = (endpoint: string, namespace: string = ''): string =
     baseUrl = getApiOrigin() ?? '';
   }
 
-  baseUrl = `${baseUrl}${resolve('', {})}`; // Append base path
+  baseUrl = `${baseUrl}${resolve('/', {})}`; // Append base path
 
   if (baseUrl.endsWith('/')) baseUrl = baseUrl.slice(0, -1);
 
