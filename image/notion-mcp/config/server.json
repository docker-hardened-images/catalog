{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.makenotion/notion-mcp-server",
    "description": "Official Notion MCP server exposing the Notion API (pages, data sources, comments, search) to MCP clients.",
    "repository": {
      "url": "https://github.com/makenotion/notion-mcp-server",
      "source": "github"
    },
    "version": "_VERSION_",
    "packages": [
      {
        "registryType": "oci",
        "registryBaseUrl": "https://dhi.io",
        "identifier": "notion-mcp:_VERSION_",
        "version": "_VERSION_",
        "transport": { "type": "stdio" },
        "runtimeArguments": [
          { "type": "named", "name": "--rm" },
          { "type": "named", "name": "-i" }
        ],
        "environmentVariables": [
          {
            "name": "NOTION_TOKEN",
            "description": "Notion internal integration token (starts with ntn_).",
            "isRequired": true,
            "isSecret": true
          }
        ]
      }
    ]
  }
