Fix buildkit v0.28.1 DockerAuthProviderConfig API change.

BuildKit v0.28.1 replaced the ConfigFile field with AuthConfigProvider
in DockerAuthProviderConfig. Use the LoadAuthConfig helper to convert
the docker config into the new provider interface.

diff --git a/core/core/patch.go b/core/core/patch.go
index 0000000..1111111 100644
--- a/core/core/patch.go
+++ b/core/core/patch.go
@@ -232,4 +232,4 @@ func patchWithContext(ctx context.Context, buildkitAddr, image, reportFile, patch
 
 	dockerConfig := config.LoadDefaultConfigFile(os.Stderr)
-	cfg := authprovider.DockerAuthProviderConfig{ConfigFile: dockerConfig}
+	cfg := authprovider.DockerAuthProviderConfig{AuthConfigProvider: authprovider.LoadAuthConfig(dockerConfig)}
 	attachable := []session.Attachable{authprovider.NewDockerAuthProvider(cfg)}
